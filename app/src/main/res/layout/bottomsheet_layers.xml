<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/layer_sheet_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/layer_sheet_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkSentinel2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/layer_sentinel2"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:buttonTint="@color/accent_scan" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkPlanet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/layer_planet"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:buttonTint="@color/accent_scan" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkUsgs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/layer_usgs"
        android:textColor="@color/text_primary"
        android:checked="false"
        app:buttonTint="@color/accent_thermal" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyLayers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/layer_apply"
        app:backgroundTint="@color/accent_scan"
        android:textColor="@color/bg_base" />

</LinearLayout>
