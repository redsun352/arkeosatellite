<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/layer_sheet_title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/layer_sheet_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkSentinel2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/layer_sentinel2"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:buttonTint="@color/accent_scan" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkPlanet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/layer_planet"
        android:textColor="@color/text_primary"
        android:checked="true"
        app:buttonTint="@color/accent_scan" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkUsgs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/layer_usgs"
        android:textColor="@color/text_primary"
        android:checked="false"
        app:buttonTint="@color/accent_thermal" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="@color/border_subtle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/season_title"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="10dp"
        android:text="@string/season_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <RadioGroup
        android:id="@+id/radioGroupSeason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radioSeasonSummer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/season_summer_drought"
            android:textColor="@color/text_primary"
            android:checked="true"
            app:buttonTint="@color/accent_scan" />

        <RadioButton
            android:id="@+id/radioSeasonSpring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/season_spring"
            android:textColor="@color/text_primary"
            app:buttonTint="@color/accent_scan" />

        <RadioButton
            android:id="@+id/radioSeasonRecent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/season_recent"
            android:textColor="@color/text_primary"
            app:buttonTint="@color/accent_scan" />

    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyLayers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/layer_apply"
        app:backgroundTint="@color/accent_scan"
        android:textColor="@color/bg_base" />

</LinearLayout>
</ScrollView>
