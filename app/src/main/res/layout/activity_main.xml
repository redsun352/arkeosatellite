<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    tools:context=".ui.MainActivity">

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Üst başlık: minimal, yarı saydam, marka + kısa talimat -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC0D1117"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/toolNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tool_polygon_title"
            android:textColor="@color/accent_scan"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/instructionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="@string/instructions_draw_polygon" />
    </LinearLayout>

    <!-- Sağda dikey araç sütunu: şekil araçları + harita tipi + katman seçici -->
    <LinearLayout
        android:id="@+id/toolColumn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/toolPolygon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:srcCompat="@drawable/ic_tool_polygon"
            app:backgroundTint="@color/accent_scan"
            app:tint="@color/bg_base"
            app:fabSize="mini"
            android:contentDescription="@string/tool_polygon_title" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/toolRectangle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:srcCompat="@drawable/ic_tool_rectangle"
            app:backgroundTint="@color/bg_surface_elevated"
            app:tint="@color/text_primary"
            app:fabSize="mini"
            android:contentDescription="@string/tool_rectangle_title" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/toolCircle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:srcCompat="@drawable/ic_tool_circle"
            app:backgroundTint="@color/bg_surface_elevated"
            app:tint="@color/text_primary"
            app:fabSize="mini"
            android:contentDescription="@string/tool_circle_title" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/toolMapType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:srcCompat="@drawable/ic_satellite_view"
            app:backgroundTint="@color/bg_surface_elevated"
            app:tint="@color/text_primary"
            app:fabSize="mini"
            android:contentDescription="@string/map_type_toggle_title" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/toolLayers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_layers"
            app:backgroundTint="@color/accent_thermal"
            app:tint="@color/bg_base"
            app:fabSize="mini"
            android:contentDescription="@string/layer_selector_title" />

    </LinearLayout>

    <!-- Alt kontrol paneli: durum + ilerleme + aksiyon butonları -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_subtle"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:progressTint="@color/accent_scan" />

            <!-- Birinci satır: Geri al / Temizle / Bitir -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUndo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/btn_undo_point"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:strokeColor="@color/border_subtle"
                    style="?attr/materialButtonOutlinedStyle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/btn_clear_polygon"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    app:strokeColor="@color/border_subtle"
                    style="?attr/materialButtonOutlinedStyle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinishPolygon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/btn_finish_polygon"
                    android:textColor="@color/bg_base"
                    android:textSize="12sp"
                    app:backgroundTint="@color/accent_thermal"
                    android:enabled="false" />
            </LinearLayout>

            <!-- İkinci satır: Analizi Başlat (tam genişlik, vurgulu) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRunAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_run_analysis"
                app:backgroundTint="@color/accent_scan"
                android:textColor="@color/bg_base"
                android:enabled="false" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
