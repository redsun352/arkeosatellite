<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Sadece HTTPS - tüm uydu API'leri (GEE, Copernicus, USGS) zaten TLS kullanıyor -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
