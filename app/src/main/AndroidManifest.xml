<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 3D anomali yüzeyi görselleştirmesi için (ResultActivity, HeightmapGlRenderer) -->
    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <!-- Uydu API çağrıları için internet erişimi -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Harita üzerinde "konumum" gösterimi için (opsiyonel, saha gezintisi yok ama kullanıcı kendi konumunu görmek isteyebilir) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.ArkeoSARSat"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Google Maps API key - gradle.properties / local.properties üzerinden enjekte edilir -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.ResultActivity"
            android:exported="false"
            android:label="@string/result_activity_title" />

    </application>

</manifest>
